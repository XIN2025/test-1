generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model AdminEmail {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  email String @unique

  @@map("admin_emails")
}

model ChatConfig {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  model           String
  chatAgentPrompt String
  webSearchPrompt String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("chat_config")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auth      UserAuth?
  profile   UserProfile?
  chats     Chat[]
  chatStats UserChatStat?

  @@map("users")
}

model UserAuth {
  id                          String       @id @default(auto()) @map("_id") @db.ObjectId
  userId                      String       @unique @db.ObjectId
  provider                    AuthProvider
  verificationToken           String?
  verificationTokenExpiresAt  DateTime?
  password                    String?
  passwordResetToken          String?
  passwordResetTokenExpiresAt DateTime?
  isVerified                  Boolean      @default(false)
  verifiedAt                  DateTime?
  createdAt                   DateTime     @default(now())
  updatedAt                   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_auths")
}

model UserProfile {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @unique @db.ObjectId
  gender           Gender
  karmiPoints      Int      @default(50)
  dateOfBirth      DateTime
  timeOfBirth      String?
  placeOfBirth     String
  horoscopeDetails Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Chat {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  title  String @default("New Chat")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatMessages ChatMessage[]

  @@index([userId])
  @@index([updatedAt])
  @@map("chats")
}

model ChatMessage {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  chatId      String   @db.ObjectId
  role        String
  parts       Json?
  attachments Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([updatedAt])
  @@map("chat_messages")
}

model UserChatStat {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  totalQuestions  Int      @default(1)
  totalTokensUsed Int      @default(1)
  totalChats      Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([updatedAt])
  @@map("user_chat_stats")
}
