{
  "name": "karmi",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "start": "turbo run start",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo test",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:deploy": "turbo run db:deploy",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css,scss,js,jsx,html,mdx,yml,yaml}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,md,json,css,scss,js,jsx,html,mdx,yml,yaml}\"",
    "typecheck": "turbo run typecheck"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/react-syntax-highlighter": "^15.5.13",
    "eslint": "^9.29.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "turbo": "^2.5.4",
    "typescript": "5.8.2"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/google": "^1.2.19",
    "@ai-sdk/openai": "^1.3.22",
    "@repo/db": "^0.0.0",
    "@repo/shared-types": "*",
    "@tanstack/react-query": "^5.80.7",
    "ai": "^4.3.16",
    "axios": "^1.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.18.1",
    "input-otp": "^1.4.2",
    "jose": "^6.1.0",
    "jsonrepair": "^3.12.0",
    "lucide-react": "^0.475.0",
    "next-themes": "^0.4.4",
    "prisma": "^6.16.3",
    "react": "^19.0.0",
    "react-day-picker": "9.7.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.57.0",
    "react-markdown": "^10.1.0",
